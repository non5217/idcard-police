# 1. ปิดการแสดงรายการไฟล์ (Directory Listing)
Options -Indexes

# 2. ซ่อนไฟล์สำคัญ
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "^(connect\.php|config\.php|helpers\.php|admin_auth\.php|public_navbar\.php|admin_navbar\.php|announcement_functions\.php|announcement_section\.php)$">
    Require all denied
</FilesMatch>

# 3. 🛡️ Government Grade Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    # เพิ่ม Preload ตามคำแนะนำ
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # 🟢 เพิ่ม CSP: บังคับให้โหลดสคริปต์และสไตล์จากเว็บที่เชื่อถือได้เท่านั้น (รวม Cloudflare Turnstile)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://code.jquery.com https://earthchie.github.io https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://earthchie.github.io; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: blob: https://portal.pathumthani.police.go.th https://pathumthani.police.go.th; connect-src 'self' https://earthchie.github.io https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com;"
</IfModule>

# 4. ซ่อนนามสกุล .php (Clean URLs)
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # ถ้ามีคนเข้าผ่านลิงก์ที่มี .php ให้ Redirect ไปหน้าแบบไม่มี .php อัตโนมัติ
    RewriteCond %{REQUEST_METHOD} !POST
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # ถ้า URL ที่เข้ามาไม่ใช่ไฟล์หรือโฟลเดอร์ที่มีอยู่จริง ให้ระบบลองเติม .php แล้วดึงไฟล์มาแสดงเบื้องหลัง
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]
</IfModule>
